.record panda.ClassCastException <external>

.record A {}
.record B <extends=A> {}
.record C {}

#! CHECKER      CheckCast Elimination applied, replaced by Deoptimize.
#! RUN          force_jit: true, options: "--compiler-regex=_GLOBAL.*", entry: "_GLOBAL::main1"
#! METHOD       "_GLOBAL::main1"
#! PASS_AFTER   "Inline"
#! INST_NOT     "CheckCast"
#! INST         "Deoptimize"

.function u1 main1() {
    newobj v0, A
    lda.obj v0

try_begin:
    checkcast.nonnull C
    ldai 2
    return
try_end:

catch_block1_begin:
    ldai 0
    return

catch_block2_begin:
    ldai 1
    return

.catch panda.ClassCastException, try_begin, try_end, catch_block1_begin
.catchall try_begin, try_end, catch_block2_begin
}

#! CHECKER      CheckCast Elimination applied, remove redundant checkcast.nonnull.
#! RUN          force_jit: true, options: "--compiler-regex=_GLOBAL.*", entry: "_GLOBAL::main2"
#! METHOD       "_GLOBAL::main2"
#! PASS_AFTER   "Inline"
#! INST_NOT     "CheckCast"

.function u1 main2() {
    newobj v0, B
    lda.obj v0

try_begin:
    checkcast.nonnull A
    lda.null
    checkcast.nonnull A
    ldai 2
    return
try_end:

catch_block1_begin:
    ldai 0
    return

catch_block2_begin:
    ldai 1
    return

.catch panda.ClassCastException, try_begin, try_end, catch_block1_begin
.catchall try_begin, try_end, catch_block2_begin
}

#! CHECKER      CheckCast Elimination applied, remove redundant checkcast.nonnull, inline.
#! RUN          force_jit: true, options: "--compiler-regex=_GLOBAL.*", entry: "_GLOBAL::main3"

.function i32 test1() {
    newobj v0, B
    lda.obj v0
    checkcast.nonnull C
    ldai 1
    return
}

.function u1 main3() {
try_begin:
    call.short test1
    return
try_end:

catch_block1_begin:
    ldai 0
    return

catch_block2_begin:
    ldai 1
    return

.catch panda.ClassCastException, try_begin, try_end, catch_block1_begin
.catchall try_begin, try_end, catch_block2_begin
}

#! CHECKER      CheckCast Elimination applied, but NullCheck is not thrown away for field value.
#! RUN          force_jit: true, options: "--compiler-regex=_GLOBAL.*", entry: "_GLOBAL::main4"
#! METHOD       "_GLOBAL::main4"
#! PASS_AFTER   "IrBuilder"
#! INST         "NullCheck"
#! INST         "CheckCast"
#! PASS_AFTER   "ChecksElimination"
#! INST         "NullCheck"
#! INST_NOT     "CheckCast"

.record D {
    B b
}

.function u1 main4() {
    newobj v0, D
    ldobj.obj v0, D.b

try_begin:
    checkcast.nonnull A
    ldai 2
    return
try_end:

catch_block1_begin:
    ldai 0
    return

catch_block2_begin:
    ldai 1
    return

.catch panda.ClassCastException, try_begin, try_end, catch_block1_begin
.catchall try_begin, try_end, catch_block2_begin
}


#! CHECKER      CheckCast Elimination applied, remove checkcast.nonnull for method return value.
#! RUN          force_jit: true, options: "--compiler-regex=_GLOBAL.* --compiler-inlining=false", entry: "_GLOBAL::main5"
#! METHOD       "_GLOBAL::test2"
#! PASS_AFTER   "IrBuilder"
#! INST         "CheckCast"
#! PASS_AFTER   "ChecksElimination"
#! INST_NOT     "CheckCast"

.function A createB() {
    newobj v0, B
    lda.obj v0
    return.obj
}

.function void test2(u1 a0) {
    lda a0
    jnez make_call
    newobj v1, A
    lda.obj v1
    jmp check
make_call:
    call.short createB
check:
    checkcast.nonnull A
    return.void
}

.function u1 main5() {
try_begin:
    movi v0, 0
    call.short test2, v0
    movi v0, 1
    call.short test2, v0
    ldai 0
    return
try_end:

catch_block1_begin:
    ldai 2
    return

catch_block2_begin:
    ldai 1
    return

.catch panda.ClassCastException, try_begin, try_end, catch_block1_begin
.catchall try_begin, try_end, catch_block2_begin
}

#! CHECKER      CheckCast is not replaced to Deoptimize because return value can be subclass of return class.
#! RUN          force_jit: true, options: "--compiler-regex=_GLOBAL.* --compiler-inlining=false", entry: "_GLOBAL::main6"
#! METHOD       "_GLOBAL::test3"
#! PASS_AFTER   "Codegen"
#! INST         "CheckCast"

.function u1 test3(u1 a0) {
    lda a0
    jnez make_call
    newobj v1, A
    lda.obj v1
    jmp check
make_call:
    call.short createB
check:
try_begin:
    checkcast.nonnull B
    ldai 0
    return
try_end:
catch_block_begin:
    ldai 1
    return
.catch panda.ClassCastException, try_begin, try_end, catch_block_begin
}

.function u1 main6() {
try_begin:
    movi v0, 0
    call.short test3, v0
    jeqz exit_failure
    movi v0, 1
    call.short test3, v0
    return
try_end:

catch_block_begin:
    ldai 2
    return

exit_failure:
    ldai 3
    return

.catchall  try_begin, try_end, catch_block_begin
}

#! CHECKER      CheckCast and NullCheck are not replaced to Deoptimize, ClassCastException called.
#! RUN          force_jit: true, options: "--compiler-regex=_GLOBAL.* --compiler-inlining=false", entry: "_GLOBAL::main7"
#! EVENT_NOT    /DeoptimizationReason,.*,CHECK_CAST/
#! EVENT        /Exception,.*,CAST_CHECK/
#!
#! METHOD       "_GLOBAL::test4"
#! PASS_AFTER   "Codegen"
#! INST         "NullCheck"
#! INST         "CheckCast"

.function u1 test4(u32 a0) {
    movi v1, 1
    movi v2, 2
    lda a0
    jeq v1, create_a
    jeq v2, create_b

create_null:
    lda.null
    jmp check
create_a:
    newobj v3, A
    lda.obj v3
    jmp check
create_b:
    call.short createB

check:
try_begin:
    checkcast.nonnull B
    ldai 0
    return
try_end:
catch_block_begin:
    ldai 1
    return

.catch panda.ClassCastException, try_begin, try_end, catch_block_begin
}

.function u1 main7() {
try_begin:
    movi v0, 0
    call.short test4, v0
    jeqz exit_failure
    movi v0, 1
    call.short test4, v0
    jeqz exit_failure
    movi v0, 2
    call.short test4, v0
    return
try_end:

catch_block_begin:
    ldai 3
    return

exit_failure:
    ldai 4
    return

.catchall  try_begin, try_end, catch_block_begin
}
