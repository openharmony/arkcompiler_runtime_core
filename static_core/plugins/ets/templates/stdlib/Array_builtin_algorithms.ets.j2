export function copyTo(src: FixedArray<{{T}}>, dst: FixedArray<{{T}}>, dstStart: int, srcStart: int, srcEnd: int): void {
    if (srcStart < 0 || srcStart > srcEnd || srcEnd > src.length) {
        throw new ArrayIndexOutOfBoundsError("copyTo: src bounds verification failed")
