{
  "name": "@panda/declgen",
  "version": "1.0.0",
  "main": "build/src/index.js",
  "bin": "build/src/main.js",
  "files": [
    "build/*"
  ],
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "tsc": "tsc",
    "install_tsc": "./script/install_tsc.sh",
    "postinstall": "npm run install_tsc",
    "webpack": "webpack -t node --config webpack.config.js",
    "clean": "rimraf build dist bundle",
    "compile": "npm run tsc && node script/write-impl-hash.js",
    "compile:release": "tsc -p tsconfig.release.json && node script/write-impl-hash.js",
    "build": "npm run clean && npm run compile",
    "build:release": "npm run clean && npm run compile:release",
    "pack:declgen": "rimraf bundle && mkdir bundle && npm pack --pack-destination bundle",
    "eslint-check": "npx eslint",
    "eslint-fix": "npm run eslint-check -- --fix",
    "prettier-fix": "npx prettier --write .",
    "fix": "npm run prettier-fix && npm run eslint-fix",
    "declgen": "node ./build/src/main.js",
    "test": "npm run compile && npm run test:cookbook && npm run test:unit",
    "test:unit": "mocha \"build/test/unit/**/*.test.js\"",
    "test:cookbook-one": "node build/test/framework/CookbookExecutor.js",
    "test:cookbook": "TEST_OUT=build/test_artifacts_parallel && rimraf ${TEST_OUT} && node build/test/framework/CookbookRunner.js --test-dir test/cookbook_tests -t ts_source -t dts_declarations -t package_source --test-out-dir ${TEST_OUT}",
    "bench:build": "tsc -p benchmark/tsconfig.json",
    "bench:fetch": "bash benchmark/scripts/fetch-fixtures.sh",
    "bench": "npm run bench:build && node build/benchmark/src/runner.js"
  },
  "dependencies": {
    "commander": "^9.4.0",
    "jest-diff": "^30.2.0",
    "kleur": "^4.1.5",
    "log4js": "^6.4.0",
    "typescript": "npm:ohos-typescript@4.9.5-r9"
  },
  "devDependencies": {
    "@eslint/js": "8.57.1",
    "@types/mocha": "10.0.10",
    "@types/node": "18.11.7",
    "eslint": "8.57.1",
    "mocha": "10.8.2",
    "prettier": "3.5.3",
    "rimraf": "6.0.1",
    "typescript-eslint": "8.8.0",
    "webpack": "5.72.1",
    "webpack-cli": "5.0.2"
  }
}
