#! CHECKER      String.copyTo.NullPtr.Array gJIT
#! RUN          force_jit: true, options: "--compiler-regex='.*testCopyTo.*'", entry: "_GLOBAL::main"

.language eTS

.record arkruntime.annotation.Module <external>
.record std.core.Byte <external>
.record std.core.Short <external>
.record std.core.Int <external>
.record std.core.Long <external>
.record std.core.String <external>
.record std.core.Error <external>
.record std.core.NullPointerError <external>
.record std.core.ETSGLOBAL <external>

.function i32 testCopyToByteNullFirst() <static, access.function=public> {
try_begin_label_0:
        mov.null v2
        movi v0, 1
        newarr v3, v0, std.core.Byte[]
        movi v4, 0
        movi v5, 0
        movi v6, 1
        call.range std.core.ETSGLOBAL.copyTo:(std.core.Byte[],std.core.Byte[],i32,i32,i32), v2
        ldai 0x1
        return
try_end_label_0:
        sta.obj v0
        lda.obj v0
        isinstance std.core.NullPointerError
        jeqz jump_label_2
        ldai 0x0
        return
jump_label_2:
        ldai 0x2
        return

.catch std.core.Error, try_begin_label_0, try_end_label_0, try_end_label_0
}

