#! CHECKER      Static Any Ldbyval and Stbyval INT
#! RUN          options: "--compiler-enable-jit=false", entry: "_GLOBAL::main"

#! CHECKER      Static Any Ldbyval and Stbyval JIT
#! RUN          force_jit: true, options: "--compiler-regex='_GLOBAL::test_(st|ld)byval.*'", entry: "_GLOBAL::main"
#! METHOD       "_GLOBAL::test_ldbyval"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyLdbyval/
#! METHOD       "_GLOBAL::test_stbyval"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyStbyval/

#! CHECKER      Static Any Ldbyval and Stbyval AOT
#! RUN_PAOC     options: "--compiler-regex='_GLOBAL::test_(st|ld)byval.*'"
#! METHOD       "_GLOBAL::test_ldbyval"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyLdbyval/
#! METHOD       "_GLOBAL::test_stbyval"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyStbyval/
#! RUN          entry: "_GLOBAL::main"

.language eTS

.record std.core.Object <external>

.record std.core.String <external>

.record X <ets.extends=std.core.Object, access.record=public> {
    std.core.String prop <access.field=public>
}

.function i32 test_stbyval(std.core.Object a0) <static, access.function=public> {
    lda.obj a0
    checkcast X
    sta.obj v2
    lda.str "prop"
    sta.obj v3
    lda.str "uuu"
    sta.obj v4
    any.stbyval v2, v3
    ldobj.obj v2, X.prop
    sta.obj v5
    ets.equals v4, v5
    return
}

.function i32 test_ldbyval(std.core.Object a0) <static, access.function=public> {
    lda.obj a0
    sta.obj v2
    lda.str "prop"
    sta.obj v3
    any.ldbyval v2, v3
    sta.obj v4
    lda.str "uuu"
    sta.obj v5
    ets.equals v4, v5
    return
}

.function i32 main() <static, access.function=public> {
    initobj.short X._ctor_:(X)
    sta.obj v0
    call.short test_stbyval:(std.core.Object), v0
    jeqz exit_bad_st
    call.short test_ldbyval:(std.core.Object), v0
    jeqz exit_bad_ld
    ldai 0
    return
exit_bad_st:
    ldai -1
    return
exit_bad_ld:
    ldai -2
    return
}

.function void X._ctor_(X a0) <ctor, access.function=public> {
    call.short std.core.Object._ctor_:(std.core.Object), a0
    lda.str "ooooooo"
    stobj.obj a0, X.prop
    return.void
}

.function void std.core.Object._ctor_(std.core.Object a0) <ctor, external, access.function=public>
