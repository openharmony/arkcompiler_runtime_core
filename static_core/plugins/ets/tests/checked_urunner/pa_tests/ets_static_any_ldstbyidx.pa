#! CHECKER      Static Any Ldbyidx and Stbyidx INT
#! RUN          options: "--compiler-enable-jit=false", entry: "_GLOBAL::main"

#! CHECKER      Static Any Ldbyidx and Stbyidx JIT
#! RUN          force_jit: true, options: "--compiler-regex='_GLOBAL::test_(st|ld)byidx.*'", entry: "_GLOBAL::main"
#! METHOD       "_GLOBAL::test_ldbyidx"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyLdbyidx/
#! METHOD       "_GLOBAL::test_stbyidx"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyStbyidx/

#! CHECKER      Static Any Ldbyidx and Stbyidx AOT
#! RUN_PAOC     options: "--compiler-regex='_GLOBAL::test_(st|ld)byidx.*'"
#! METHOD       "_GLOBAL::test_ldbyidx"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyLdbyidx/
#! METHOD       "_GLOBAL::test_stbyidx"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyStbyidx/
#! RUN          entry: "_GLOBAL::main"

.language eTS

.record std.core.Array <external>

.record std.core.Int <external>

.record std.core.Object <external>

.record std.core.String <external>

.record Y <external>

.function i32 test_stbyidx(std.core.Object a0) <static, access.function=public> {
    lda.obj a0
    checkcast std.core.Array
    sta.obj v2
    fldai.64 0x0
    sta.64 v3
    lda.str "test"
    any.stbyidx v2, v3, 0x0
    movi v0, 0x0
    call.short std.core.Array.$_get:(std.core.Array,i32), v2, v0
    sta.obj v4
    lda.str "test"
    sta.obj v5
    ets.equals v4, v5
    return
}

.function i32 test_ldbyidx(std.core.Object a0) <static, access.function=public> {
    lda.obj a0
    sta.obj v1
    fldai.64 0x0
    sta.64 v2
    lda.64 v2
    any.ldbyidx v1, 0x0
    sta.obj v3
    lda.str "test"
    sta.obj v4
    ets.equals v3, v4
    return
}

.function std.core.Array init_array() <static, access.function=public> {
    movi v0, 0x0
    movi v2, 0x1
    newarr v1, v2, std.core.Object[]
    movi v3, 21
    initobj.short std.core.Int._ctor_:(std.core.Int,i32), v3
    starr.obj v1, v0
    lenarr v1
    sta v2
    initobj.short std.core.Array._ctor_:(std.core.Array,i32), v2
    sta.obj v3
jump_label_1:
    lda v0
    jge v2, jump_label_0
    lda v0
    ldarr.obj v1
    call.acc std.core.Array.$_set:(std.core.Array,i32,Y), v3, v0, v0, 0x2
    inci v0, 0x1
    jmp jump_label_1
jump_label_0:
    lda.obj v3
    return.obj
}

.function i32 main() <static, access.function=public> {
    call.short init_array:()
    sta.obj v0
    call.short test_stbyidx:(std.core.Object), v0
    jeqz exit_bad_st
    call.short test_ldbyidx:(std.core.Object), v0
    jeqz exit_bad_ld
    ldai 0
    return
exit_bad_st:
    ldai -1
    return
exit_bad_ld:
    ldai -2
    return
}

.function Y std.core.Array.$_get(std.core.Array a0, i32 a1) <native, external, access.function=public>

.function void std.core.Array.$_set(std.core.Array a0, i32 a1, Y a2) <native, external, access.function=public>

.function void std.core.Array._ctor_(std.core.Array a0, i32 a1) <ctor, external, access.function=public>

.function void std.core.Int._ctor_(std.core.Int a0, i32 a1) <ctor, external, access.function=public>
