#! CHECKER      Static Any Isinstance INT
#! RUN          options: "--compiler-enable-jit=false", entry: "_GLOBAL::main"

#! CHECKER      Static Any Isinstance JIT
#! RUN          force_jit: true, options: "--compiler-regex='.*testIsinstance.*'", entry: "_GLOBAL::main"
#! METHOD       "_GLOBAL::testIsinstanceSameClass"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyIsinstance/
#! METHOD       "_GLOBAL::testIsinstanceDifferentClass"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyIsinstance/

#! CHECKER      Static Any Isinstance AOT
#! RUN_PAOC     options: "--compiler-regex='.*testIsinstance.*'"
#! METHOD       "_GLOBAL::testIsinstanceSameClass"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyIsinstance/
#! METHOD       "_GLOBAL::testIsinstanceDifferentClass"
#! PASS_AFTER   "IrBuilder"
#! INST         /Intrinsic.CompilerAnyIsinstance/
#! RUN          entry: "_GLOBAL::main"

.language eTS

.record std.core.Object <external>

.record A <ets.extends=std.core.Object, access.record=public> {
    i32 x
}

.record B <ets.extends=std.core.Object, access.record=public> {
    i32 y
}

.function void A._ctor_(A a0) <ctor, access.function=public> {
    call.short std.core.Object._ctor_:(std.core.Object), a0
    ldai 1
    stobj a0, A.x
    return.void
}

.function void B._ctor_(B a0) <ctor, access.function=public> {
    call.short std.core.Object._ctor_:(std.core.Object), a0
    ldai 2
    stobj a0, B.y
    return.void
}

.function i32 testIsinstanceSameClass() {
    initobj.short A._ctor_:(A)
    sta.obj v0          # v0 = new A()
    initobj.short A._ctor_:(A)
    sta.obj v1          # v1 = new A() (used as "class" operand)
    lda.obj v0
    any.isinstance v1, 0x0   # acc = v0 instanceof v1
    return
}

.function i32 testIsinstanceDifferentClass() {
    initobj.short A._ctor_:(A)
    sta.obj v0          # v0 = new A()
    initobj.short B._ctor_:(B)
    sta.obj v1          # v1 = new B()
    lda.obj v0
    any.isinstance v1, 0x0   # acc = v0 instanceof v1
    return
}

.function i32 main() <static, access.function=public> {
    call.short testIsinstanceSameClass
    call.short testIsinstanceDifferentClass
    ldai 0
    # NOTE(zavedeevdenis): Check the result when the static version of any.isinstance is implemented
    return
}

.function void std.core.Object._ctor_(std.core.Object a0) <ctor, external, access.function=public>
