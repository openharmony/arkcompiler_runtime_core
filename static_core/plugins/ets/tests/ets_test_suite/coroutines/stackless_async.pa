.language eTS

# class Pair {
#     ref: Object;
#     primitive: long;
# }
# 
# async function async_foo(p: Promise<Pair>): Pair {
#     let ref = new Object();
#     let primitive = 42;
#     let pair = await p;
#     pair.ref = ref;
#     pair.primitive = primitive;
#     return pair;
# }
# 
# function main() {
#     let pair = new Pair();
#     let p = Promise.resolve(pair);
#     async_foo(p);
# }

.record arkruntime.AsyncContext <external>
.record std.core.Promise <external>
.record std.core.Object <external>

.function arkruntime.AsyncContext arkruntime.AsyncContext.current() <external>
.function arkruntime.AsyncContext arkruntime.AsyncContext.init() <external>
.function std.core.Promise arkruntime.AsyncContext.resolve(arkruntime.AsyncContext a0, std.core.Object a1) <external>
.function std.core.Promise std.core.Promise.resolve(std.core.Object a0) <external>
.function std.core.Object std.core.Promise.awaitResolution(std.core.Promise a0) <external>

.record Pair {
    std.core.Object ref
    i64 primitive
}

# NOTE(panferovi): add @async annotation
.function std.core.Promise async_foo(std.core.Promise a0) {
    call.short arkruntime.AsyncContext.current                        # async function prologue begin
    sta.obj v0                                                      #
    ets.async.dispatch v0                                           #
                                                                    #
    call.short arkruntime.AsyncContext.init                           #
    sta.obj v0                                                      # end

    newobj v1, std.core.Object                                      # let ref = new Object();
    movi.64 v2, 42                                                  # let primitive = 42;

    call.virt.short std.core.Promise.awaitResolution, a0            #
    ets.async.suspend v0                                            #
    checkcast Pair                                                  #
    sta.obj v3                                                      # let pair = await p;

    lda.obj v1                                                      #
    stobj.obj v3, Pair.ref                                          # pair.ref = ref;
    lda.64 v2                                                       #
    stobj.64 v3, Pair.primitive                                     # pair.primitive = primitive;

    call.virt.short arkruntime.AsyncContext.resolve, v0, v3           #
    return.obj                                                      # return pair;
}

.function void main() <static> {
    newobj v0, Pair                                                 # let pair = new Pair();
	call.short std.core.Promise.resolve, v0                         #
    sta.obj v0                                                      # let p = Promise.resolve(pair);

    call.short async_foo, v0                                        # async_foo(p);

    # we need to call async_foo once again (to execute dispatch inst)
    # until this is supported in the CoroutineManager
    call.short async_foo, v0

    return.void
}
