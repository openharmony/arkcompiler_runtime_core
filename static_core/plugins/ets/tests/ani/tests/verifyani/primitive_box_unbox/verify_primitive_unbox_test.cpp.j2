TEST_F(PrimitiveUnbox{{ Type }}Test, wrong_result)
{
    ani_object object = BoxValue(TEST_VALUE);

    ASSERT_EQ(env_->Primitive_Unbox_{{ Type }}(object, nullptr), ANI_INVALID_ARGS);
    std::vector<TestLineInfo> testLines {
