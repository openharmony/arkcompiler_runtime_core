// NOLINTBEGIN(readability-magic-numbers)

class PrimitiveUnbox{{ Type }}Test : public VerifyAniTest {
public:
    static constexpr ani_{{ type }} TEST_VALUE = {{ test_value }};
{% if type == "char" %}
    static constexpr ani_char OPTIONAL_VALUE = 'z';
{% else %}
    static constexpr ani_{{ type }} OPTIONAL_VALUE = TEST_VALUE;
{% endif %}
{% if type == "byte" %}
    static constexpr ani_char WRONG_VALUE = 'A';
{% else %}
    static constexpr auto WRONG_VALUE = static_cast<ani_byte>(7);
{% endif %}

    ani_object BoxValue(ani_{{ type }} value)
    {
        ani_object object {};
        EXPECT_EQ(env_->Primitive_Box_{{ Type }}(value, &object), ANI_OK);
        EXPECT_NE(object, nullptr);
        return object;
    }

    ani_object BoxWrongTypeValue()
    {
        ani_object object {};
{% if type == "byte" %}
        EXPECT_EQ(env_->Primitive_Box_Char(WRONG_VALUE, &object), ANI_OK);
{% else %}
        EXPECT_EQ(env_->Primitive_Box_Byte(WRONG_VALUE, &object), ANI_OK);
{% endif %}
        EXPECT_NE(object, nullptr);
        return object;
    }

    static void AssertIs{{ Type }}(ani_env *env, ani_object boxed)
    {
        ani_class typeClass {};
        ASSERT_EQ(env->FindClass("std.core.{{ Type }}", &typeClass), ANI_OK);

        ani_boolean isExpectedType = ANI_FALSE;
        ASSERT_EQ(env->Object_InstanceOf(boxed, typeClass, &isExpectedType), ANI_OK);
        ASSERT_EQ(isExpectedType, ANI_TRUE);
    }

};

static void TestUnboxFromFieldNative(ani_env *env)
{
    ani_class cls {};
    ASSERT_EQ(env->FindClass("@defModule.ani_verify_test_primitive_unbox_{{ type }}.Message", &cls), ANI_OK);

    ani_method ctor {};
    ASSERT_EQ(env->Class_FindMethod(cls, "<ctor>", ":", &ctor), ANI_OK);

    ani_object object {};
    ASSERT_EQ(env->Object_New(cls, ctor, &object), ANI_OK);

    ani_field field {};
    ASSERT_EQ(env->Class_FindField(cls, "value_optional", &field), ANI_OK);

    ani_ref boxedValue {};
    ASSERT_EQ(env->Object_GetField_Ref(object, field, &boxedValue), ANI_OK);

    ani_{{ type }} result {};
    ASSERT_EQ(env->Primitive_Unbox_{{ Type }}(static_cast<ani_object>(boxedValue), &result), ANI_OK);
    ASSERT_EQ(result, PrimitiveUnbox{{ Type }}Test::OPTIONAL_VALUE);
}

TEST_F(PrimitiveUnbox{{ Type }}Test, wrong_env)
{
    ani_object object = BoxValue(TEST_VALUE);
    ani_{{ type }} result {};

    ASSERT_EQ(env_->c_api->Primitive_Unbox_{{ Type }}(nullptr, object, &result), ANI_INVALID_ARGS);
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *", "env is nullptr [ERROR]"},
        {"obj", "ani_object"},
        {"result", "ani_{{ type }} *"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Primitive_Unbox_{{ Type }}", testLines);
}

TEST_F(PrimitiveUnbox{{ Type }}Test, wrong_object)
{
    ani_{{ type }} result {};

    ASSERT_EQ(env_->Primitive_Unbox_{{ Type }}(nullptr, &result), ANI_INVALID_ARGS);
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *"},
        {"obj", "ani_object", "reference is nullptr [ERROR]"},
        {"result", "ani_{{ type }} *"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Primitive_Unbox_{{ Type }}", testLines);
}

TEST_F(PrimitiveUnbox{{ Type }}Test, null_object)
{
    ani_object object {};
    ASSERT_EQ(env_->GetNull(reinterpret_cast<ani_ref *>(&object)), ANI_OK);
    ani_{{ type }} result {};

    ASSERT_EQ(env_->Primitive_Unbox_{{ Type }}(object, &result), ANI_ERROR);
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *"},
        {"obj", "ani_object", "wrong reference type: null [FATAL]"},
        {"result", "ani_{{ type }} *"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Primitive_Unbox_{{ Type }}", testLines);
}

TEST_F(PrimitiveUnbox{{ Type }}Test, non_boxed_object)
{
    ani_string string {};
    ASSERT_EQ(env_->String_NewUTF8("test", 4U, &string), ANI_OK);
    ani_{{ type }} result {};
    const std::string expectedError = "wrong boxed primitive type, actual: std.core.String, "
                                      "expected: std.core.{{ Type }} [ERROR]";

    ASSERT_EQ(env_->Primitive_Unbox_{{ Type }}(reinterpret_cast<ani_object>(string), &result), ANI_INVALID_TYPE);
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *"},
        {"obj", "ani_object", expectedError},
        {"result", "ani_{{ type }} *"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Primitive_Unbox_{{ Type }}", testLines);
}

