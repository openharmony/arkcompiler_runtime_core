TEST_F(PrimitiveUnbox{{ Type }}Test, throw_error)
{
    ani_object object = BoxValue(TEST_VALUE);
    ThrowError();

    ani_{{ type }} result {};
    ASSERT_EQ(env_->Primitive_Unbox_{{ Type }}(object, &result), ANI_PENDING_ERROR);
    ASSERT_EQ(env_->ResetError(), ANI_OK);

    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *", "has a pending exception [ERROR]"},
        {"obj", "ani_object"},
        {"result", "ani_{{ type }} *"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Primitive_Unbox_{{ Type }}", testLines);
}

TEST_F(PrimitiveUnbox{{ Type }}Test, success)
{
{% if type == "boolean" %}
    constexpr std::array<ani_{{ type }}, 2U> VALUES {ANI_FALSE, ANI_TRUE};
{% else %}
    constexpr std::array<ani_{{ type }}, 4U> VALUES { {{ min_value }}, {{ max_value }}, {{ zero_value }}, TEST_VALUE };
{% endif %}

    for (auto value : VALUES) {
        ani_object object = BoxValue(value);
        AssertIs{{ Type }}(env_, object);

        ani_{{ type }} result {};
        ASSERT_EQ(env_->Primitive_Unbox_{{ Type }}(object, &result), ANI_OK);
        ASSERT_EQ(result, value);
    }
}

TEST_F(PrimitiveUnbox{{ Type }}Test, ets_optional_field)
{
    ani_module module {};
    ASSERT_EQ(env_->FindModule("@defModule.ani_verify_test_primitive_unbox_{{ type }}", &module), ANI_OK);

    ani_function etsFunc {};
    ASSERT_EQ(env_->Module_FindFunction(module, "testUnboxFromField", ":", &etsFunc), ANI_OK);

    ani_native_function nativeFunc {"testUnboxFromFieldNative", ":",
                                    reinterpret_cast<void *>(TestUnboxFromFieldNative)};
    ASSERT_EQ(env_->Module_BindNativeFunctions(module, &nativeFunc, 1U), ANI_OK);

    ASSERT_EQ(env_->Function_Call_Void(etsFunc), ANI_OK);
}

