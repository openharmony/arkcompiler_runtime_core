#include <array>
#include <cfloat>
#include <climits>
#include <cstdint>

#include "plugins/ets/tests/ani/ani_gtest/verify_ani_gtest.h"

namespace ark::ets::ani::verify::testing {

// NOLINTBEGIN(readability-magic-numbers)

class PrimitiveBox{{ Type }}Test : public VerifyAniTest {
public:
    static constexpr ani_{{ type }} TEST_VALUE = {{ test_value }};

    static void AssertIs{{ Type }}(ani_env *env, ani_object boxed)
    {
        ani_class typeClass {};
        ASSERT_EQ(env->FindClass("std.core.{{ Type }}", &typeClass), ANI_OK);

        ani_boolean isExpectedType = ANI_FALSE;
        ASSERT_EQ(env->Object_InstanceOf(boxed, typeClass, &isExpectedType), ANI_OK);
        ASSERT_EQ(isExpectedType, ANI_TRUE);
    }
};

static ani_object TestWithArgsNative(ani_env *env, ani_{{ type }} value)
{
    ani_object object {};
    ani_status status = env->Primitive_Box_{{ Type }}(value, &object);
    if (status != ANI_OK) {
        return nullptr;
    }
    PrimitiveBox{{ Type }}Test::AssertIs{{ Type }}(env, object);
    return object;
}

TEST_F(PrimitiveBox{{ Type }}Test, wrong_env)
{
    ani_object object {};
    ASSERT_EQ(env_->c_api->Primitive_Box_{{ Type }}(nullptr, TEST_VALUE, &object), ANI_INVALID_ARGS);
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *", "called from incorrect the native scope"},
        {"value", "ani_{{ type }}"},
        {"result", "ani_object *"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Primitive_Box_{{ Type }}", testLines);
}

TEST_F(PrimitiveBox{{ Type }}Test, wrong_result)
{
    ASSERT_EQ(env_->Primitive_Box_{{ Type }}(TEST_VALUE, nullptr), ANI_INVALID_ARGS);
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *"},
        {"value", "ani_{{ type }}"},
        {"result", "ani_object *", "nullptr for storing 'ani_object'"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Primitive_Box_{{ Type }}", testLines);
}

TEST_F(PrimitiveBox{{ Type }}Test, wrong_all_args)
{
    ASSERT_EQ(env_->c_api->Primitive_Box_{{ Type }}(nullptr, TEST_VALUE, nullptr), ANI_INVALID_ARGS);
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *", "called from incorrect the native scope"},
        {"value", "ani_{{ type }}"},
        {"result", "ani_object *", "nullptr for storing 'ani_object'"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Primitive_Box_{{ Type }}", testLines);
}

{% if type == "boolean" %}
TEST_F(PrimitiveBox{{ Type }}Test, wrong_value)
{
    ani_object object {};
    ASSERT_EQ(env_->Primitive_Box_Boolean(static_cast<ani_boolean>(2U), &object), ANI_ERROR);
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *"},
        {"value", "ani_boolean", "wrong value for ani_boolean"},
        {"result", "ani_object *"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Primitive_Box_Boolean", testLines);
}
{% endif %}

TEST_F(PrimitiveBox{{ Type }}Test, throw_error)
{
    ThrowError();

    ani_object object {};
    ASSERT_EQ(env_->Primitive_Box_{{ Type }}(TEST_VALUE, &object), ANI_PENDING_ERROR);
    ASSERT_EQ(env_->ResetError(), ANI_OK);

    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *", "has unhandled an error"},
        {"value", "ani_{{ type }}"},
        {"result", "ani_object *"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Primitive_Box_{{ Type }}", testLines);
}

TEST_F(PrimitiveBox{{ Type }}Test, success)
{
{% if type == "boolean" %}
    constexpr std::array<ani_{{ type }}, 2U> VALUES {ANI_FALSE, ANI_TRUE};
{% else %}
    constexpr std::array<ani_{{ type }}, 4U> VALUES { {{ min_value }}, {{ max_value }}, {{ zero_value }}, TEST_VALUE };
{% endif %}

    for (auto value : VALUES) {
        ani_object object {};
        ASSERT_EQ(env_->Primitive_Box_{{ Type }}(value, &object), ANI_OK);
        ASSERT_NE(object, nullptr);
        AssertIs{{ Type }}(env_, object);
    }
}

TEST_F(PrimitiveBox{{ Type }}Test, ets_argument)
{
    ani_module module {};
    ASSERT_EQ(env_->FindModule("@defModule.ani_verify_test_primitive_box_{{ type }}", &module), ANI_OK);

    ani_function etsFunc {};
    ASSERT_EQ(env_->Module_FindFunction(module, "testWithArgs", "{{ shorty }}:C{std.core.Object}", &etsFunc),
              ANI_OK);

    ani_native_function nativeFunc {"testWithArgsNative", "{{ shorty }}:C{std.core.Object}",
                                    reinterpret_cast<void *>(TestWithArgsNative)};
    ASSERT_EQ(env_->Module_BindNativeFunctions(module, &nativeFunc, 1U), ANI_OK);

    ani_ref result {};
    ASSERT_EQ(env_->Function_Call_Ref(etsFunc, &result, TEST_VALUE), ANI_OK);
    AssertIs{{ Type }}(env_, static_cast<ani_object>(result));
}

// NOLINTEND(readability-magic-numbers)

}  // namespace ark::ets::ani::verify::testing
