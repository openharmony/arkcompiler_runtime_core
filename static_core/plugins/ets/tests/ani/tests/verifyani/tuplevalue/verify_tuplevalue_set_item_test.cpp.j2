#include "plugins/ets/tests/ani/tests/verifyani/tuplevalue/verify_tuplevalue_test_utils.h"

// NOLINTBEGIN(readability-magic-numbers)

namespace ark::ets::ani::verify::testing {

class TupleValueSetItem{{ Type }}Test : public VerifyAniTupleValueTestBase {
protected:
    static constexpr std::string_view MODULE_NAME = "ani_verify_test_tuplevalue_set_item_{{ type }}";
    static constexpr ani_size VALID_INDEX = 0U;
    static constexpr ani_size OUT_OF_RANGE_INDEX = 3U;
{% if type != "ref" %}
    static constexpr ani_{{ type }} VALID_VALUE = {{ valid_cpp_value }};
    static constexpr ani_{{ type }} UPDATED_VALUE = {{ updated_cpp_value }};
{% endif %}
{% if type == "boolean" %}
    static constexpr ani_boolean INVALID_VALUE = 2;
{% endif %}

    ani_tuple_value GetValidTuple()
    {
        return GetTupleWithCheck(MODULE_NAME, "get{{ Type }}Tuple");
    }
};

TEST_F(TupleValueSetItem{{ Type }}Test, wrong_env)
{
    ani_tuple_value tupleValue = GetValidTuple();
{% if type == "ref" %}
    ani_string value {};
    CreateString("tuplevalue-item", &value);
    ASSERT_EQ(env_->c_api->TupleValue_SetItem_{{ Type }}(nullptr, tupleValue, VALID_INDEX, value), ANI_INVALID_ARGS);
{% else %}
    const ani_{{ type }} value = VALID_VALUE;
    ASSERT_EQ(env_->c_api->TupleValue_SetItem_{{ Type }}(nullptr, tupleValue, VALID_INDEX, value), ANI_INVALID_ARGS);
{% endif %}
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *", "env is nullptr [ERROR]"},
        {"tuple_value", "ani_tuple_value"},
        {"index", "ani_size"},
        {"value", "ani_{{ type }}"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("TupleValue_SetItem_{{ Type }}", testLines);
}

