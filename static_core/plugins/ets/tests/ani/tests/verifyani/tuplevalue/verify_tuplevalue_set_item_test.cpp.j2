TEST_F(TupleValueSetItem{{ Type }}Test, success)
{
    ani_tuple_value tupleValue = GetValidTuple();
{% if type == "ref" %}
    ani_string value {};
    CreateString("tuplevalue-updated", &value);
    ASSERT_EQ(env_->TupleValue_SetItem_Ref(tupleValue, VALID_INDEX, value), ANI_OK);

    ani_ref result {};
    ASSERT_EQ(env_->TupleValue_GetItem_Ref(tupleValue, VALID_INDEX, &result), ANI_OK);
    AssertStringRefEqual(result, "tuplevalue-updated");
{% else %}
    ASSERT_EQ(env_->TupleValue_SetItem_{{ Type }}(tupleValue, VALID_INDEX, UPDATED_VALUE),
              ANI_OK);

    ani_{{ type }} result {};
    ASSERT_EQ(env_->TupleValue_GetItem_{{ Type }}(tupleValue, VALID_INDEX, &result), ANI_OK);
    AssertAniValueEqual(result, UPDATED_VALUE);
{% endif %}
}

