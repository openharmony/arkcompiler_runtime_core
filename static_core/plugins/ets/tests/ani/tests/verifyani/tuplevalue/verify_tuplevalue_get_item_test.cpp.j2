TEST_F(TupleValueGetItem{{ Type }}Test, success)
{
    ani_tuple_value tupleValue = GetValidTuple();
    ani_{{ type }} result {};

    ASSERT_EQ(env_->TupleValue_GetItem_{{ Type }}(tupleValue, VALID_INDEX, &result), ANI_OK);
{% if type == "ref" %}
    AssertStringRefEqual(result, "alpha");
{% else %}
    AssertAniValueEqual(result, EXPECTED_VALUE);
{% endif %}
}

