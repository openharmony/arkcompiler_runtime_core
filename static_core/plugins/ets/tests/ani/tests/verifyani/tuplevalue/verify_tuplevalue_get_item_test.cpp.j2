#include "plugins/ets/tests/ani/tests/verifyani/tuplevalue/verify_tuplevalue_test_utils.h"

// NOLINTBEGIN(readability-magic-numbers)

namespace ark::ets::ani::verify::testing {

class TupleValueGetItem{{ Type }}Test : public VerifyAniTupleValueTestBase {
protected:
    static constexpr std::string_view MODULE_NAME = "ani_verify_test_tuplevalue_get_item_{{ type }}";
    static constexpr ani_size VALID_INDEX = 0U;
    static constexpr ani_size OUT_OF_RANGE_INDEX = 3U;
{% if type != "ref" %}
    static constexpr ani_{{ type }} EXPECTED_VALUE = {{ expected_cpp_value }};
{% endif %}

    ani_tuple_value GetValidTuple()
    {
        return GetTupleWithCheck(MODULE_NAME, "get{{ Type }}Tuple");
    }
};

TEST_F(TupleValueGetItem{{ Type }}Test, wrong_env)
{
    ani_tuple_value tupleValue = GetValidTuple();
    ani_{{ type }} result {};

    ASSERT_EQ(env_->c_api->TupleValue_GetItem_{{ Type }}(nullptr, tupleValue, VALID_INDEX, &result), ANI_ERROR);
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *", "called from incorrect the native scope"},
        {"tuple_value", "ani_tuple_value"},
        {"index", "ani_size"},
        {"result", "ani_{{ type }} *"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("TupleValue_GetItem_{{ Type }}", testLines);
}

TEST_F(TupleValueGetItem{{ Type }}Test, wrong_tuple)
{
    ani_{{ type }} result {};
    ASSERT_EQ(env_->TupleValue_GetItem_{{ Type }}(nullptr, VALID_INDEX, &result), ANI_ERROR);
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *"},
        {"tuple_value", "ani_tuple_value", "wrong reference"},
        {"index", "ani_size"},
        {"result", "ani_{{ type }} *"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("TupleValue_GetItem_{{ Type }}", testLines);
}

