TEST_F(ClassSetStaticFieldByName{{ Type }}Test, call_on_global_ref)
{
    ani_class gclass {};
    ASSERT_EQ(env_->GlobalReference_Create(class_, reinterpret_cast<ani_ref *>(&gclass)), ANI_OK);

    ani_{{ type }} value = GetTestValue(env_);
    ASSERT_EQ(env_->c_api->Class_SetStaticFieldByName_{{ Type }}(env_, gclass, "{{ type }}Field", value), ANI_OK);
}

TEST_F(ClassSetStaticFieldByName{{ Type }}Test, cross_thread_call_on_global_ref)
{
    ani_class gclass {};
    ASSERT_EQ(env_->GlobalReference_Create(class_, reinterpret_cast<ani_ref *>(&gclass)), ANI_OK);

    std::thread([this, gclass]() {
        ani_env *env {};
        ASSERT_EQ(vm_->AttachCurrentThread(nullptr, ANI_VERSION_1, &env), ANI_OK);

        ani_{{ type }} value = GetTestValue(env);
        ASSERT_EQ(env->c_api->Class_SetStaticFieldByName_{{ Type }}(env, gclass, "{{ type }}Field", value), ANI_OK);

        ASSERT_EQ(vm_->DetachCurrentThread(), ANI_OK);
    }).join();
}

