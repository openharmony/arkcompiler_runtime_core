class ClassSetStaticFieldByName{{ Type }}Test : public VerifyAniTest {
public:
    static ani_{{ type }} GetTestValue(ani_env *env)
    {
{% if type == "ref" %}
        ani_string value {};
        ani_status status = env->String_NewUTF8("test", 4U, &value);
        EXPECT_EQ(status, ANI_OK);
        return value;
{% else %}
        static_cast<void>(env);
        return {{ cpp_value }};
{% endif %}
    }

    void SetUp() override
    {
        VerifyAniTest::SetUp();
        ASSERT_EQ(env_->FindClass("ani_verify_test_class_set_static_field_by_name_{{ type }}.Parent", &class_),
                  ANI_OK);
    }

protected:
    ani_class class_ {};  // NOLINT(misc-non-private-member-variables-in-classes)
};

TEST_F(ClassSetStaticFieldByName{{ Type }}Test, success)
{
    ani_{{ type }} value = GetTestValue(env_);
    ASSERT_EQ(env_->c_api->Class_SetStaticFieldByName_{{ Type }}(env_, class_, "{{ type }}Field", value), ANI_OK);
}

TEST_F(ClassSetStaticFieldByName{{ Type }}Test, set_then_get)
{
    ani_{{ type }} value = GetTestValue(env_);
    ASSERT_EQ(env_->c_api->Class_SetStaticFieldByName_{{ Type }}(env_, class_, "{{ type }}Field", value), ANI_OK);

    ani_{{ type }} result {};
    ASSERT_EQ(env_->c_api->Class_GetStaticFieldByName_{{ Type }}(env_, class_, "{{ type }}Field", &result), ANI_OK);
{% if type != "ref" %}
    ASSERT_EQ(result, value);
{% endif %}
}

