TEST_F(ClassCallStaticMethodByName{{ Type }}Test, wrong_env)
{
    ASSERT_EQ(env_->FindClass("ani_verify_test_class_call_static_method_by_name_{{ type }}.Parent", &class_), ANI_OK);
{% if type == "void" %}
    ASSERT_EQ(env_->c_api->Class_CallStaticMethodByName_{{ Type }}(
                  nullptr, class_, "static{{ Type }}Method", "zcbsilfdC{std.core.String}:",
                  z_, c_, b_, s_, i_, l_, f_, d_, r_),
              ANI_ERROR);
{% else %}
    ani_{{ type }} result {};
    ASSERT_EQ(env_->c_api->Class_CallStaticMethodByName_{{ Type }}(
                  nullptr, class_, "static{{ Type }}Method", "zcbsilfdC{std.core.String}:{{ ret }}", &result,
                  z_, c_, b_, s_, i_, l_, f_, d_, r_),
              ANI_ERROR);
{% endif %}
    // clang-format off
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *", "called from incorrect the native scope"},
        {"class", "ani_class"},
        {"name", "const char *"},
        {"signature", "const char *"},
    };
    // clang-format on
    ASSERT_ERROR_ANI_ARGS_MSG("Class_CallStaticMethodByName_{{ Type }}", testLines);
}

