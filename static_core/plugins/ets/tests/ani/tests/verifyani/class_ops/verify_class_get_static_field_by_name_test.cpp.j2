#include <thread>

#include "plugins/ets/tests/ani/ani_gtest/verify_ani_gtest.h"

namespace ark::ets::ani::verify::testing {

class ClassGetStaticFieldByName{{ Type }}Test : public VerifyAniTest {
public:
    void SetUp() override
    {
        VerifyAniTest::SetUp();
        ASSERT_EQ(env_->FindClass("ani_verify_test_class_get_static_field_by_name_{{ type }}.Parent", &class_),
                  ANI_OK);
    }

protected:
    ani_class class_ {};  // NOLINT(misc-non-private-member-variables-in-classes)
};

TEST_F(ClassGetStaticFieldByName{{ Type }}Test, success)
{
    ani_{{ type }} result {};
    ASSERT_EQ(env_->c_api->Class_GetStaticFieldByName_{{ Type }}(env_, class_, "{{ type }}Field", &result), ANI_OK);
}

TEST_F(ClassGetStaticFieldByName{{ Type }}Test, wrong_env)
{
    ani_{{ type }} result {};
    ASSERT_EQ(env_->c_api->Class_GetStaticFieldByName_{{ Type }}(nullptr, class_, "{{ type }}Field", &result),
              ANI_ERROR);
    // clang-format off
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *", "called from incorrect the native scope"},
        {"class", "ani_class"},
        {"name", "const char *"},
        {"result", "ani_{{ type }} *"},
    };
    // clang-format on
    ASSERT_ERROR_ANI_ARGS_MSG("Class_GetStaticFieldByName_{{ Type }}", testLines);
}

