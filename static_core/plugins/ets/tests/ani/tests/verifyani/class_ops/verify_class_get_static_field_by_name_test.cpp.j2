TEST_F(ClassGetStaticFieldByName{{ Type }}Test, class_from_local_scope)
{
    ani_class cls {};
    const int nr3 = 3;
    ASSERT_EQ(env_->CreateLocalScope(nr3), ANI_OK);
    ASSERT_EQ(env_->FindClass("ani_verify_test_class_get_static_field_by_name_{{ type }}.Parent", &cls), ANI_OK);
    ASSERT_EQ(env_->DestroyLocalScope(), ANI_OK);

    ani_{{ type }} result {};
    ASSERT_EQ(env_->c_api->Class_GetStaticFieldByName_{{ Type }}(env_, cls, "{{ type }}Field", &result), ANI_ERROR);
    // clang-format off
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *"},
        {"class", "ani_class", "wrong reference"},
        {"name", "const char *", "wrong class for static field"},
        {"result", "ani_{{ type }} *"},
    };
    // clang-format on
    ASSERT_ERROR_ANI_ARGS_MSG("Class_GetStaticFieldByName_{{ Type }}", testLines);
}

TEST_F(ClassGetStaticFieldByName{{ Type }}Test, class_from_escape_local_scope)
{
    ani_class cls {};
    const int nr3 = 3;
    ASSERT_EQ(env_->CreateEscapeLocalScope(nr3), ANI_OK);
    ASSERT_EQ(env_->FindClass("ani_verify_test_class_get_static_field_by_name_{{ type }}.Parent", &cls), ANI_OK);
    ASSERT_EQ(env_->DestroyEscapeLocalScope(cls, reinterpret_cast<ani_ref *>(&class_)), ANI_OK);

    ani_{{ type }} result {};
    ASSERT_EQ(env_->c_api->Class_GetStaticFieldByName_{{ Type }}(env_, class_, "{{ type }}Field", &result), ANI_OK);
}

TEST_F(ClassGetStaticFieldByName{{ Type }}Test, call_on_global_ref)
{
    ani_class gclass {};
    ASSERT_EQ(env_->GlobalReference_Create(class_, reinterpret_cast<ani_ref *>(&gclass)), ANI_OK);

    ani_{{ type }} result {};
    ASSERT_EQ(env_->c_api->Class_GetStaticFieldByName_{{ Type }}(env_, gclass, "{{ type }}Field", &result), ANI_OK);
}

TEST_F(ClassGetStaticFieldByName{{ Type }}Test, cross_thread_call_on_global_ref)
{
    ani_class gclass {};
    ASSERT_EQ(env_->GlobalReference_Create(class_, reinterpret_cast<ani_ref *>(&gclass)), ANI_OK);

    std::thread([this, gclass]() {
        ani_env *env {};
        ASSERT_EQ(vm_->AttachCurrentThread(nullptr, ANI_VERSION_1, &env), ANI_OK);

        ani_{{ type }} result {};
        ASSERT_EQ(env->c_api->Class_GetStaticFieldByName_{{ Type }}(env, gclass, "{{ type }}Field", &result), ANI_OK);

        ASSERT_EQ(vm_->DetachCurrentThread(), ANI_OK);
    }).join();
}

TEST_F(ClassGetStaticFieldByName{{ Type }}Test, pending_error)
{
    ThrowError();

    ani_{{ type }} result {};
    ASSERT_EQ(env_->c_api->Class_GetStaticFieldByName_{{ Type }}(env_, class_, "{{ type }}Field", &result), ANI_ERROR);
    // clang-format off
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *", "has unhandled an error"},
        {"class", "ani_class"},
        {"name", "const char *"},
        {"result", "ani_{{ type }} *"},
    };
    // clang-format on
    ASSERT_ERROR_ANI_ARGS_MSG("Class_GetStaticFieldByName_{{ Type }}", testLines);
}

