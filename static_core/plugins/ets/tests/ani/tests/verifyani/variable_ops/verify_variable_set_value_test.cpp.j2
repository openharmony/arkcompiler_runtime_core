TEST_F(VariableSetValue{{ Type }}Test, wrong_type)
{
    ani_variable variable {};
    ASSERT_EQ(env_->Namespace_FindVariable(ns_, "wrongValue", &variable), ANI_OK);
    ASSERT_NE(variable, nullptr);

{% if type == "ref" %}
    ani_string value {};
    ASSERT_EQ(env_->String_NewUTF8("{{ test_value[1:-1] }}", sizeof("{{ test_value[1:-1] }}") - 1U, &value), ANI_OK);
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(env_, variable, value), ANI_INVALID_TYPE);
{% else %}
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(env_, variable, {{ test_value }}), ANI_INVALID_TYPE);
{% endif %}
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *"},
        {% if type == "int" %}
        {"variable", "ani_variable", "field return type mismatch: byte, expected: int [ERROR]"},
        {% elif type == "ref" %}
        {"variable", "ani_variable", "field return type mismatch: int, expected: object [ERROR]"},
        {% else %}
        {"variable", "ani_variable", "field return type mismatch: int, expected: {{ type }} [ERROR]"},
        {% endif %}
        {"value", "ani_{{ type }}"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Variable_SetValue_{{ Type }}", testLines);
}

