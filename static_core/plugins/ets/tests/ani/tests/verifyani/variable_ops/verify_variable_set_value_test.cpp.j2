TEST_F(VariableSetValue{{ Type }}Test, local_scope)
{
    ani_variable variable {};
    ASSERT_EQ(env_->Namespace_FindVariable(ns_, "value", &variable), ANI_OK);
    ASSERT_NE(variable, nullptr);

    ASSERT_EQ(env_->CreateLocalScope(3U), ANI_OK);
{% if type == "ref" %}
    ani_string value {};
    ASSERT_EQ(env_->String_NewUTF8("{{ alt_value[1:-1] }}", sizeof("{{ alt_value[1:-1] }}") - 1U, &value), ANI_OK);
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(env_, variable, value), ANI_OK);
{% else %}
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(env_, variable, {{ alt_value }}), ANI_OK);
{% endif %}
    ASSERT_EQ(env_->DestroyLocalScope(), ANI_OK);
    ASSERT_NO_ABORT_MESSAGE();
}

TEST_F(VariableSetValue{{ Type }}Test, set_then_get)
{
    ani_variable variable {};
    ASSERT_EQ(env_->Namespace_FindVariable(ns_, "value", &variable), ANI_OK);
    ASSERT_NE(variable, nullptr);

{% if type == "ref" %}
    ani_string value {};
    ASSERT_EQ(env_->String_NewUTF8("{{ alt_value[1:-1] }}", sizeof("{{ alt_value[1:-1] }}") - 1U, &value), ANI_OK);
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(env_, variable, value), ANI_OK);

    ani_ref result {};
    ASSERT_EQ(env_->c_api->Variable_GetValue_{{ Type }}(env_, variable, &result), ANI_OK);

    std::string str;
    GetStdString(static_cast<ani_string>(result), str);
    ASSERT_EQ(str, "{{ alt_value[1:-1] }}");
{% else %}
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(env_, variable, {{ alt_value }}), ANI_OK);

    ani_{{ type }} result {};
    ASSERT_EQ(env_->c_api->Variable_GetValue_{{ Type }}(env_, variable, &result), ANI_OK);
    ASSERT_EQ(result, {{ alt_value }});
{% endif %}
    ASSERT_NO_ABORT_MESSAGE();
}

}  // namespace ark::ets::ani::verify::testing
