{% if type == "ref" %}
    ani_string value {};
    ASSERT_EQ(env_->String_NewUTF8("{{ test_value[1:-1] }}", sizeof("{{ test_value[1:-1] }}") - 1U, &value), ANI_OK);
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(env_, fakeVariable, value), ANI_ERROR);
{% else %}
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(env_, fakeVariable, {{ test_value }}), ANI_ERROR);
{% endif %}
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *"},
        {"variable", "ani_variable", "variable is not a verified ani_variable handle or has the wrong ANI handle type [FATAL]"},
