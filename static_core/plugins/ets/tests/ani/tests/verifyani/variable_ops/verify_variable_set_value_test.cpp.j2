#include "plugins/ets/tests/ani/ani_gtest/verify_ani_gtest.h"

namespace ark::ets::ani::verify::testing {

class VariableSetValue{{ Type }}Test : public VerifyAniTest {
public:
    void SetUp() override
    {
        VerifyAniTest::SetUp();
        ASSERT_EQ(env_->FindNamespace("ani_verify_test_variable_set_value_{{ type }}.anyns", &ns_), ANI_OK);
        ASSERT_NE(ns_, nullptr);
    }

protected:
    ani_namespace ns_ {};  // NOLINT(misc-non-private-member-variables-in-classes)
};

TEST_F(VariableSetValue{{ Type }}Test, success)
{
    ani_variable variable {};
    ASSERT_EQ(env_->Namespace_FindVariable(ns_, "value", &variable), ANI_OK);
    ASSERT_NE(variable, nullptr);

{% if type == "ref" %}
    ani_string value {};
    ASSERT_EQ(env_->String_NewUTF8("{{ test_value[1:-1] }}", sizeof("{{ test_value[1:-1] }}") - 1U, &value), ANI_OK);
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(env_, variable, value), ANI_OK);
{% else %}
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(env_, variable, {{ test_value }}), ANI_OK);
{% endif %}
    ASSERT_NO_ABORT_MESSAGE();
}

TEST_F(VariableSetValue{{ Type }}Test, null_env)
{
    ani_variable variable {};
    ASSERT_EQ(env_->Namespace_FindVariable(ns_, "value", &variable), ANI_OK);
    ASSERT_NE(variable, nullptr);

{% if type == "ref" %}
    ani_string value {};
    ASSERT_EQ(env_->String_NewUTF8("{{ test_value[1:-1] }}", sizeof("{{ test_value[1:-1] }}") - 1U, &value), ANI_OK);
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(nullptr, variable, value), ANI_INVALID_ARGS);
{% else %}
    ASSERT_EQ(env_->c_api->Variable_SetValue_{{ Type }}(nullptr, variable, {{ test_value }}), ANI_INVALID_ARGS);
{% endif %}
    std::vector<TestLineInfo> testLines {
        {"env", "ani_env *", "env is nullptr [ERROR]"},
        {"variable", "ani_variable"},
        {"value", "ani_{{ type }}"},
    };
    ASSERT_ERROR_ANI_ARGS_MSG("Variable_SetValue_{{ Type }}", testLines);
}

