        ASSERT_EQ(
            env->c_api->Object_SetPropertyByName_{{ Type }}(env, object, "{{ type }}Property", valueObj), ANI_OK);
        {% else %}
        ASSERT_EQ(
            env->c_api->Object_SetPropertyByName_{{ Type }}(env, object, "{{ type }}Property", {{ value }}),
            ANI_OK);
        {% endif %}
    }
};

