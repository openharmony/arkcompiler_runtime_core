#include "plugins/ets/tests/ani/ani_gtest/verify_ani_gtest.h"

namespace ark::ets::ani::verify::testing {

class ObjectSetPropertyByName{{ Type }}Test : public VerifyAniTest {
public:
    static void GetClassAndObject(ani_env *env, ani_class *cls, const char *className, ani_object *object)
    {
        // NOLINTBEGIN(cppcoreguidelines-pro-type-vararg)
        ASSERT_EQ(env->FindClass(className, cls), ANI_OK);
        ASSERT_NE(*cls, nullptr);

        ani_method ctor {};
        ASSERT_EQ(env->Class_FindMethod(*cls, "<ctor>", ":", &ctor), ANI_OK);

        ASSERT_EQ(env->Object_New(*cls, ctor, object), ANI_OK);
        ASSERT_NE(*object, nullptr);
        // NOLINTEND(cppcoreguidelines-pro-type-vararg)
    }

    void SetUp() override
    {
        VerifyAniTest::SetUp();
    }

protected:
    ani_class class_ {};    // NOLINT(misc-non-private-member-variables-in-classes)
    ani_object object_ {};  // NOLINT(misc-non-private-member-variables-in-classes)
};

class A {
public:
    static void NativeFoo(ani_env *env, ani_object)
    {
        ani_class cls {};
        ani_object object {};
        ObjectSetPropertyByName{{ Type }}Test::GetClassAndObject(
            env, &cls, "ani_verify_test_object_set_property_by_name_{{ type }}.Parent", &object);

        {% if type == "ref" %}
        ani_object valueObj {};
        ObjectSetPropertyByName{{ Type }}Test::GetClassAndObject(
            env, &cls, "ani_verify_test_object_set_property_by_name_{{ type }}.Parent", &valueObj);
        ASSERT_EQ(env->c_api->Object_SetPropertyByName_{{ Type }}(env, object, "{{ type }}Prop", valueObj), ANI_OK);
        {% else %}
        ASSERT_EQ(env->c_api->Object_SetPropertyByName_{{ Type }}(env, object, "{{ type }}Prop", {{ value }}), ANI_OK);
        {% endif %}
    }

    static void NativeBaz(ani_env *env, ani_object)
    {
        ani_class cls {};
