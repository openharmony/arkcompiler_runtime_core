TEST_F(ObjectSetFieldByName{{ Type }}Test, cross_thread_set_field_on_global_ref)
{
    GetClassAndObject(env_, &class_, "ani_verify_test_object_set_field_by_name_{{ type }}.Parent", &object_);

    ani_object gobject {};
    ASSERT_EQ(env_->GlobalReference_Create(object_, reinterpret_cast<ani_ref *>(&gobject)), ANI_OK);

    {% if type == "ref" %}
    ani_ref gvalue {};
    ani_ref value = GetTestRefValue(env_);
    ASSERT_EQ(env_->GlobalReference_Create(value, &gvalue), ANI_OK);
    std::thread([this, gobject, gvalue]() {
        ani_env *env {};
        ASSERT_EQ(vm_->AttachCurrentThread(nullptr, ANI_VERSION_1, &env), ANI_OK);

        ASSERT_EQ(env->c_api->Object_SetFieldByName_Ref(env, gobject, "refField", gvalue), ANI_OK);

        ASSERT_EQ(vm_->DetachCurrentThread(), ANI_OK);
    }).join();
    {% else %}
    std::thread([this, gobject]() {
        ani_env *env {};
        ASSERT_EQ(vm_->AttachCurrentThread(nullptr, ANI_VERSION_1, &env), ANI_OK);

        ani_{{ type }} value = GetTestValue();
        ASSERT_EQ(env->c_api->Object_SetFieldByName_{{ Type }}(env, gobject, "{{ type }}Field", value), ANI_OK);

        ASSERT_EQ(vm_->DetachCurrentThread(), ANI_OK);
    }).join();
    {% endif %}
}

TEST_F(ObjectSetFieldByName{{ Type }}Test, cross_thread_field_set)
{
    std::thread([this]() {
        ani_env *env {};
        ASSERT_EQ(vm_->AttachCurrentThread(nullptr, ANI_VERSION_1, &env), ANI_OK);

        ani_class cls {};
        ani_object object {};
        GetClassAndObject(env, &cls, "ani_verify_test_object_set_field_by_name_{{ type }}.Parent", &object);

        ani_{{ type }} value = GetValidArgValue(env);
        ASSERT_EQ(env->c_api->Object_SetFieldByName_{{ Type }}(env, object, "{{ type }}Field", value), ANI_OK);

        ASSERT_EQ(vm_->DetachCurrentThread(), ANI_OK);
    }).join();

    GetClassAndObject(env_, &class_, "ani_verify_test_object_set_field_by_name_{{ type }}.Parent", &object_);

    ani_{{ type }} value = GetValidArgValue(env_);
    ASSERT_EQ(env_->c_api->Object_SetFieldByName_{{ Type }}(env_, object_, "{{ type }}Field", value), ANI_OK);
}

TEST_F(ObjectSetFieldByName{{ Type }}Test, cross_thread_field_set_from_native_method)
{
    GetClassAndObject(env_, &class_, "ani_verify_test_object_set_field_by_name_{{ type }}.Parent", &object_);

    std::array methods = {ani_native_function {"foo", ":", reinterpret_cast<void *>(A::NativeFoo)},
                          ani_native_function {"baz", ":", reinterpret_cast<void *>(A::NativeBaz)}};
    ASSERT_EQ(env_->Class_BindNativeMethods(class_, methods.data(), methods.size()), ANI_OK);

    std::thread([this]() {
        ani_env *env {};
        ASSERT_EQ(vm_->AttachCurrentThread(nullptr, ANI_VERSION_1, &env), ANI_OK);

        ani_class cls {};
        ani_object object {};
        GetClassAndObject(env, &cls, "ani_verify_test_object_set_field_by_name_{{ type }}.Parent", &object);

        ASSERT_EQ(env->Object_CallMethodByName_Void(object, "foo", ":"), ANI_OK);

        ASSERT_EQ(vm_->DetachCurrentThread(), ANI_OK);
    }).join();

    ASSERT_EQ(env_->Object_CallMethodByName_Void(object_, "baz", ":"), ANI_OK);
}

