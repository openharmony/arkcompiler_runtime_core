class ObjectSetFieldByName{{ Type }}Test : public VerifyAniTest {
public:
    static void GetClassAndObject(ani_env *env, ani_class *cls, const char *className, ani_object *object)
    {
        // NOLINTBEGIN(cppcoreguidelines-pro-type-vararg)
        ASSERT_EQ(env->FindClass(className, cls), ANI_OK);
        ASSERT_NE(*cls, nullptr);

        ani_method ctor {};
        ASSERT_EQ(env->Class_FindMethod(*cls, "<ctor>", ":", &ctor), ANI_OK);

        ASSERT_EQ(env->Object_New(*cls, ctor, object), ANI_OK);
        ASSERT_NE(*object, nullptr);
        // NOLINTEND(cppcoreguidelines-pro-type-vararg)
    }

    static ani_{{ type }} GetTestValue()
    {
        {% if type == "boolean" %}
        return ANI_TRUE;
        {% elif type == "char" %}
        return static_cast<ani_char>('Z');
        {% elif type == "byte" %}
        return static_cast<ani_byte>(-7);
        {% elif type == "short" %}
        return static_cast<ani_short>(1234);
        {% elif type == "int" %}
        return 123456;
        {% elif type == "long" %}
        return static_cast<ani_long>(123456789LL);
        {% elif type == "float" %}
        return static_cast<ani_float>(3.25f);
        {% elif type == "double" %}
        return static_cast<ani_double>(6.5);
        {% else %}
        return nullptr;
        {% endif %}
    }

    {% if type == "ref" %}
    static ani_ref GetTestRefValue(ani_env *env)
    {
        ani_class cls {};
        ani_object object {};
        GetClassAndObject(env, &cls, "ani_verify_test_object_set_field_by_name_ref.Parent", &object);
        return reinterpret_cast<ani_ref>(object);
    }
    {% endif %}

    static ani_{{ type }} GetValidArgValue(ani_env *env)
    {
        {% if type == "ref" %}
        return GetTestRefValue(env);
        {% else %}
        static_cast<void>(env);
        return GetTestValue();
        {% endif %}
    }

    void SetUp() override
    {
        VerifyAniTest::SetUp();
    }

protected:
    ani_class class_ {};    // NOLINT(misc-non-private-member-variables-in-classes)
    ani_object object_ {};  // NOLINT(misc-non-private-member-variables-in-classes)
};

class A {
public:
    static void NativeFoo(ani_env *env, ani_object object)
    {
        ani_{{ type }} value = ObjectSetFieldByName{{ Type }}Test::GetValidArgValue(env);
        ASSERT_EQ(env->c_api->Object_SetFieldByName_{{ Type }}(env, object, "{{ type }}Field", value), ANI_OK);
    }

    static void NativeBaz(ani_env *env, ani_object object)
    {
        ani_{{ type }} value = ObjectSetFieldByName{{ Type }}Test::GetValidArgValue(env);
        ASSERT_EQ(env->c_api->Object_SetFieldByName_{{ Type }}(env, object, "{{ type }}Field", value), ANI_OK);
    }
};

