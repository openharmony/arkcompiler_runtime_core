.language eTS


.record Y <external>
.record N <external>

.record A {
    Y field <access.field=public>
}

.record B {
    Y field <access.field=public>
    Y field2 <access.field=public>
}

.record C {
    Y[] field <access.field=public>
}

.record F {
    N field <access.field=public>
}

.record D {
    N field <access.field=public>
    N field2 <access.field=public>
}

.function void main() <static, access.function=public> {
    return.void
}
