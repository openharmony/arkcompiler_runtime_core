function testNumericAndCurrencyPatterns(): void {
    assertAllMatches(new RegExp("^[-+]?([0-9]+)?(\\Ÿ´[0-9]{1,})?$"), ['0Ÿ´0000000000001']);
    assertAllMatches(new RegExp("^(?:[-+])?(?:[0-9]+)?(?:\\Ÿ´[0-9]*)?(?:[eE][\\+\\-]?(?:[0-9]+))?$"), ['123Ÿ´', '123Ÿ´123', '-123Ÿ´123']);
    assertAllMatches(new RegExp("^[A-Z0-9_\\-]*$", "iu"), ['']);
    assertAllMatches(new RegExp("^(?!-? )(?=.*\\d)(\\¬•)?-?(0|[1-9]\\d|[1-9]\\d{0,2}(\\,\\d{3})*)?(\\.(\\d{2}))?$"), [
        '¬•6,954,231',
        '¬•-6,954,231',
    ]);
}

